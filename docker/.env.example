# DURANDAL Environment Configuration
# Copy to .env and fill in values: cp .env.example .env

# ============================================
# REQUIRED — Generate before first run
# ============================================

# Session encryption secret (generate: openssl rand -base64 32)
NEXTAUTH_SECRET=change-me-in-production

# Internal API token for Hermes ↔ NanoClaw communication (generate: openssl rand -hex 32)
DURANDAL_API_TOKEN=change-me-in-production

# ============================================
# LLM Configuration
# ============================================

# Default local model (pulled by Ollama on first start)
OLLAMA_DEFAULT_MODEL=qwen2.5:7b

# Optional: Cloud LLM API keys (leave empty for local-only mode)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=

# ============================================
# Security
# ============================================

# Master key for credential vault encryption (generate: openssl rand -base64 32)
# If not set, derives from NEXTAUTH_SECRET
VAULT_MASTER_KEY=

# License key (optional — community tier is free)
DURANDAL_LICENSE_KEY=

# ============================================
# Telemetry (off by default)
# ============================================

# Set to "true" to enable anonymous usage telemetry
DURANDAL_TELEMETRY_ENABLED=false
